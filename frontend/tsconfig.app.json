{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "paths": {
      "@core/*":         ["src/app/core/*"],
      "@shared/*":       ["src/app/shared/*"],
      "@features/*":     ["src/app/features/*"],
      "@environments/*": ["src/environments/*"]
    }
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/environments/environment.prod.ts"]
}
